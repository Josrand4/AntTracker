<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EDE7E3">

    <!-- Back Arrow -->
    <ImageView
        android:id="@+id/ivBack"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_back"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Circle Background -->
    <View
        android:id="@+id/circleBg"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:background="@drawable/bg_circle_green"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/ivBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Icon -->
    <ImageView
        android:id="@+id/ivMail"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:src="@drawable/ic_mail_check"
        app:layout_constraintTop_toTopOf="@id/circleBg"
        app:layout_constraintBottom_toBottomOf="@id/circleBg"
        app:layout_constraintStart_toStartOf="@id/circleBg"
        app:layout_constraintEnd_toEndOf="@id/circleBg"/>

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Verification Code"
        android:textStyle="bold"
        android:textSize="20sp"
        android:textColor="#000000"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/circleBg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Subtitle -->
    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Enter the 5-digit code we've sent to *****97"
        android:textColor="#777777"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- OTP Boxes -->
    <LinearLayout
        android:id="@+id/otpContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            style="@style/OtpBoxStyle"/>

        <EditText
            style="@style/OtpBoxStyle"
            android:layout_marginStart="8dp"/>

        <EditText
            style="@style/OtpBoxStyle"
            android:layout_marginStart="8dp"/>

        <EditText
            style="@style/OtpBoxStyle"
            android:layout_marginStart="8dp"/>

        <EditText
            style="@style/OtpBoxStyle"
            android:layout_marginStart="8dp"/>

    </LinearLayout>

    <!-- Resend -->
    <TextView
        android:id="@+id/tvResend"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Didn’t receive the OTP? Resend"
        android:textColor="#0F3D2E"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/otpContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Cancel Button -->
    <Button
        android:id="@+id/btnCancel"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="Cancel"
        android:textColor="#0F3D2E"
        android:background="@drawable/bg_button_outline"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/tvResend"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnVerify"
        app:layout_constraintHorizontal_weight="1"/>

    <!-- Verify Button -->
    <Button
        android:id="@+id/btnVerify"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="Verify"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_button"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintTop_toTopOf="@id/btnCancel"
        app:layout_constraintBottom_toBottomOf="@id/btnCancel"
        app:layout_constraintStart_toEndOf="@id/btnCancel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_weight="1"/>

</androidx.constraintlayout.widget.ConstraintLayout>